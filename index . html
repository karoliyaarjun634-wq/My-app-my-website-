<script>
let userData={name:'123',email:'',goal:4,points:190,streak:0,rank:981,challengesCompleted:2};
if(localStorage.getItem('userData')){userData=JSON.parse(localStorage.getItem('userData'));document.getElementById('welcomeScreen').classList.remove('active');document.getElementById('mainApp').classList.add('active');updateDisplay();}
const goalSlider=document.getElementById('goalSlider');const goalValue=document.getElementById('goalValue');
